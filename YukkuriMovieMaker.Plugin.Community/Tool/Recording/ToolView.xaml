<UserControl x:Class="YukkuriMovieMaker.Plugin.Community.Tool.Recording.ToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="360"
             xmlns:c="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Controls"
             d:DesignWidth="520">
    <UserControl.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="収録UI" FontWeight="Bold" Margin="0,2,0,0" />
        <Button Grid.Row="1"
                Content="セリフ録音を開く"
                Command="{Binding OpenRecordingWindowCommand}"
                MinWidth="170"
                HorizontalAlignment="Left"
                Margin="0,6,0,10" />

        <Separator Grid.Row="2" Margin="0,0,0,8" />

        <TextBlock Grid.Row="3" Text="録音デバイス" Margin="0,0,0,2" />
        <DockPanel Grid.Row="4" Margin="0,0,0,0">
            <Button Content="更新"
                    Command="{Binding RefreshDevicesCommand}"
                    MinWidth="70"
                    Margin="8,0,0,0"
                    DockPanel.Dock="Right" />
            <ComboBox ItemsSource="{Binding AvailableDevices}"
                      SelectedItem="{Binding SelectedDevice}"
                      MinWidth="280" />
        </DockPanel>

        <TextBlock Grid.Row="5"
                   Text="{Binding RecordsDirectory, StringFormat=保存先: {0}}"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0" />

        <StackPanel Grid.Row="6" Margin="0,10,0,0">
            <WrapPanel>
                <Button Content="録音開始"
                        Command="{Binding StartRecordingCommand}"
                        MinWidth="120"
                        Margin="0,0,8,8" />
                <Button Content="録音停止"
                        Command="{Binding StopRecordingCommand}"
                        MinWidth="120"
                        Margin="0,0,8,8" />
            </WrapPanel>

            <TextBlock Text="{Binding RecordingStatus}"
                       Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />

            <TextBlock Text="入力レベル" Margin="0,10,0,0" />
            <ProgressBar Minimum="0"
                         Maximum="1"
                         Value="{Binding CurrentVolume}"
                         Height="16"
                         Margin="0,4,0,0" />
        </StackPanel>
    </Grid>
</UserControl>
