<UserControl x:Class="YukkuriMovieMaker.Plugin.Community.Tool.Notepad.NotepadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:YukkuriMovieMaker.Plugin.Community.Tool.Notepad"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:pb="clr-namespace:YukkuriMovieMaker.Views.Behaviors;assembly=YukkuriMovieMaker.Plugin"
             xmlns:ps="clr-namespace:YukkuriMovieMaker.Settings;assembly=YukkuriMovieMaker.Plugin"
             xmlns:pt="clr-namespace:YukkuriMovieMaker.Views.Triggers;assembly=YukkuriMovieMaker.Plugin"
             xmlns:icons="clr-namespace:YukkuriMovieMaker.Resources.Icons;assembly=YukkuriMovieMaker.Plugin"
             xmlns:controls="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Controls"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:search="clr-namespace:ICSharpCode.AvalonEdit.Search;assembly=ICSharpCode.AvalonEdit"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type={x:Type local:NotepadViewModel}}">
    <UserControl.Resources>
        <Style TargetType="{x:Type search:SearchPanel}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type search:SearchPanel}">
                        <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                BorderThickness="1"
                                CornerRadius="3"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,4,18,0" Padding="4"
                                Cursor="Arrow">
                            <StackPanel Orientation="Horizontal">
                                <TextBox Name="PART_searchTextBox"
                                         Width="200" MinHeight="24"
                                         VerticalContentAlignment="Center"
                                         Margin="0,0,4,0">
                                    <TextBox.Text>
                                        <Binding Path="SearchPattern"
                                                 RelativeSource="{RelativeSource TemplatedParent}"
                                                 UpdateSourceTrigger="PropertyChanged">
                                            <Binding.ValidationRules>
                                                <ExceptionValidationRule/>
                                            </Binding.ValidationRules>
                                        </Binding>
                                    </TextBox.Text>
                                </TextBox>

                                <ToggleButton IsChecked="{Binding MatchCase, RelativeSource={RelativeSource TemplatedParent}}"
                                              ToolTip="{Binding Localization.MatchCaseText, RelativeSource={RelativeSource TemplatedParent}}"
                                              Content="{DynamicResource {x:Static icons:IconKeys.FormatLetterCase}}"
                                              Width="24" Height="24"
                                              Padding="3"/>
                                <ToggleButton IsChecked="{Binding WholeWords, RelativeSource={RelativeSource TemplatedParent}}"
                                              ToolTip="{Binding Localization.MatchWholeWordsText, RelativeSource={RelativeSource TemplatedParent}}"
                                              Content="{DynamicResource {x:Static icons:IconKeys.FormatLetterMatches}}"
                                              Width="24" Height="24"
                                              Padding="3"/>
                                <ToggleButton IsChecked="{Binding UseRegex, RelativeSource={RelativeSource TemplatedParent}}"
                                              ToolTip="{Binding Localization.UseRegexText, RelativeSource={RelativeSource TemplatedParent}}"
                                              Content="{DynamicResource {x:Static icons:IconKeys.Regex}}"
                                              Width="24" Height="24"
                                              Padding="3"/>

                                <Button Command="search:SearchCommands.FindPrevious"
                                        ToolTip="{Binding Localization.FindPreviousText, RelativeSource={RelativeSource TemplatedParent}}"
                                        Content="{DynamicResource {x:Static icons:IconKeys.ChevronUp}}"
                                        Width="24" Height="24" Margin="3,0,0,0" Padding="3"/>
                                <Button Command="search:SearchCommands.FindNext"
                                        ToolTip="{Binding Localization.FindNextText, RelativeSource={RelativeSource TemplatedParent}}"
                                        Content="{DynamicResource {x:Static icons:IconKeys.ChevronDown}}"
                                        Width="24" Height="24" Padding="3"/>
                                <Button Command="search:SearchCommands.CloseSearchPanel"
                                        ToolTip="{x:Static local:Texts.SearchClose}"
                                        Content="{DynamicResource {x:Static icons:IconKeys.Close}}"
                                        Width="24" Height="24" Margin="3,0,0,0" Padding="3"
                                        Focusable="False"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <i:Interaction.Behaviors>
        <pb:OpenFileDialogBehavior ViewModel="{Binding OpenFileDialog}"/>
        <pb:SaveFileDialogBehavior ViewModel="{Binding SaveFileDialog}"/>
    </i:Interaction.Behaviors>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <ToolBarTray Grid.Row="0">
            <i:Interaction.Triggers>
                <pt:PreviewMouseWheelEventTrigger ModifierKeys="Ctrl" DeltaMode="Down" Handled="True">
                    <i:InvokeCommandAction Command="{Binding Source={x:Static ps:CommandSettings.Default},Path=[SizeDownToolBar]}" PassEventArgsToCommand="True"/>
                </pt:PreviewMouseWheelEventTrigger>
                <pt:PreviewMouseWheelEventTrigger ModifierKeys="Ctrl" DeltaMode="Up" Handled="True">
                    <i:InvokeCommandAction Command="{Binding Source={x:Static ps:CommandSettings.Default},Path=[SizeUpToolBar]}" PassEventArgsToCommand="True"/>
                </pt:PreviewMouseWheelEventTrigger>
            </i:Interaction.Triggers>
            <ToolBar Height="{Binding Source={x:Static ps:YMMSettings.Default},Path=ToolBarHeight}">
                <Button Content="{DynamicResource {x:Static icons:IconKeys.Plus}}" Command="{Binding OpenNewTabCommand}" ToolTip="{x:Static local:Texts.OpenNewTab}"/>
                <Button Content="{DynamicResource {x:Static icons:IconKeys.Folder}}" Command="{Binding OpenCommand}" ToolTip="{x:Static local:Texts.Open}"/>
                <Separator/>
                <Button Content="{DynamicResource {x:Static icons:IconKeys.ContentSave}}" Command="{Binding SaveCommand}" CommandParameter="{Binding FilePath}" ToolTip="{x:Static local:Texts.Save}"/>
                <Button Content="{DynamicResource {x:Static icons:IconKeys.ContentSaveEdit}}" Command="{Binding SaveCommand}" ToolTip="{x:Static local:Texts.SaveAs}"/>
                <Separator/>
                <Button Content="{DynamicResource {x:Static icons:IconKeys.Image}}" Command="{Binding InsertImageCommand}" ToolTip="{x:Static local:Texts.InsertImage}"/>
                <Separator/>
                <Button Content="{DynamicResource {x:Static icons:IconKeys.Magnify}}" Command="{Binding ToggleSearchCommand}" ToolTip="{x:Static local:Texts.Search}"/>
                <Separator/>
                <controls:DropDownButton Content="{DynamicResource {x:Static icons:IconKeys.Cog}}" ToolTip="{x:Static local:Texts.Settings}" BorderBrush="Transparent" Padding="3">
                    <controls:DropDownButton.Style>
                        <Style TargetType="controls:DropDownButton" BasedOn="{StaticResource {x:Type ToggleButton}}"/>
                    </controls:DropDownButton.Style>
                    <controls:DropDownButton.ContextMenu>
                        <ContextMenu DataContext="{Binding RelativeSource={RelativeSource Mode=Self},Path=PlacementTarget.DataContext}"
                                     d:DataContext="{d:DesignInstance Type={x:Type local:NotepadViewModel}}">
                            <MenuItem Header="{x:Static local:Texts.WordWrap}"
                                      IsCheckable="True"
                                      IsChecked="{Binding WordWrap, Mode=TwoWay}"
                                      Icon="{DynamicResource {x:Static icons:IconKeys.FormatTextWrappingWrap}}"/>
                            <MenuItem Header="{x:Static local:Texts.ShowLineNumbers}"
                                      IsCheckable="True"
                                      IsChecked="{Binding ShowLineNumbers, Mode=TwoWay}"
                                      Icon="{DynamicResource {x:Static icons:IconKeys.FormatListNumbered}}"/>
                        </ContextMenu>
                    </controls:DropDownButton.ContextMenu>
                </controls:DropDownButton>
            </ToolBar>
        </ToolBarTray>
        <avalon:TextEditor Grid.Row="1"
                           FontSize="{Binding FontSize}"
                           ShowLineNumbers="{Binding ShowLineNumbers}"
                           IsReadOnly="False"
                           VerticalScrollBarVisibility="Auto"
                           HorizontalScrollBarVisibility="Auto"
                           AllowDrop="True">
            <avalon:TextEditor.Options>
                <avalon:TextEditorOptions EnableHyperlinks="False" />
            </avalon:TextEditor.Options>
            <i:Interaction.Behaviors>
                <local:AvalonEditTextBindingBehavior Text="{Binding Text, Mode=TwoWay}"
                                                     WordWrap="{Binding WordWrap}"/>
                <local:NotepadImageDisplayBehavior ImageScale="{Binding Zoom}"/>
                <local:NotepadImageInputBehavior/>
                <local:NotepadSearchBehavior/>
            </i:Interaction.Behaviors>
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="PreviewMouseWheel">
                    <i:InvokeCommandAction Command="{Binding ChangeFontSizeCommand}" PassEventArgsToCommand="True"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </avalon:TextEditor>
    </Grid>
</UserControl>
