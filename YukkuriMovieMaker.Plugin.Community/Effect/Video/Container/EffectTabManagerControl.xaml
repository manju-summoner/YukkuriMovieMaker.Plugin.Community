<UserControl x:Class="YukkuriMovieMaker.Plugin.Community.Effect.Video.Container.EffectTabManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:YukkuriMovieMaker.Plugin.Community.Effect.Video.Container"
             xmlns:converters="clr-namespace:YukkuriMovieMaker.Plugin.Community.Effect.Video.Container"
             xmlns:icons="clr-namespace:YukkuriMovieMaker.Resources.Icons;assembly=YukkuriMovieMaker.Plugin"
             mc:Ignorable="d"
             d:DesignHeight="40" d:DesignWidth="700"
             Background="Transparent">

    <UserControl.Resources>
        <converters:TabCompactModeConverter x:Key="TabCompactModeConverter"/>

        <Style x:Key="TabListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="TabListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinScrollBarLineButtonStyle" TargetType="RepeatButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                BorderThickness="1"
                                CornerRadius="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Maximum="{TemplateBinding Maximum}"
                                   Minimum="{TemplateBinding Minimum}"
                                   Value="{TemplateBinding Value}"
                                   ViewportSize="{TemplateBinding ViewportSize}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Style="{StaticResource ThinScrollBarLineButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ThinScrollBarThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Style="{StaticResource ThinScrollBarLineButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="Height" Value="6"/>
                                <Setter Property="MinHeight" Value="6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Opacity" Value="0.55"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Opacity" Value="0.45"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent" Margin="5,5,5,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="Transparent"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="0,0,0,1"
                Padding="0,0,0,4">
            <ListBox x:Name="TabListBox"
                     Style="{StaticResource TabListBoxStyle}"
                     ItemContainerStyle="{StaticResource TabListBoxItemStyle}"
                     ItemsSource="{Binding Tabs}"
                     PreviewMouseWheel="TabListBox_PreviewMouseWheel"
                     SelectedItem="{Binding SelectedTab}"
                     Tag="{Binding DataContext, RelativeSource={RelativeSource Self}}"
                     AllowDrop="True"
                     PreviewMouseMove="TabListBox_PreviewMouseMove"
                     PreviewMouseLeftButtonDown="TabListBox_PreviewMouseLeftButtonDown"
                     DragOver="TabListBox_DragOver"
                     Drop="TabListBox_Drop">
                <ListBox.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="{x:Static loc:Texts.Menu_Paste}" Command="{Binding PasteCommand}" Icon="{DynamicResource {x:Static icons:IconKeys.ContentPaste}}"/>
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="TabBorder"
                                Background="{x:Null}"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                BorderThickness="1"
                                MinHeight="28"
                                Width="120"
                                Padding="6,0,4,0"
                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <Border.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="{x:Static loc:Texts.Menu_Copy}" 
                                              Command="{Binding CopyCommand}" 
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                              Icon="{DynamicResource {x:Static icons:IconKeys.ContentCopy}}"/>
                                    <MenuItem Header="{x:Static loc:Texts.Menu_Paste}" 
                                              Command="{Binding PasteCommand}" 
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                              Icon="{DynamicResource {x:Static icons:IconKeys.ContentPaste}}"/>
                                    <MenuItem Header="{x:Static loc:Texts.Menu_Duplicate}" 
                                              Command="{Binding DuplicateTabCommand}" 
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                              Icon="{DynamicResource {x:Static icons:IconKeys.ContentCopy}}"/>
                                    <Separator/>
                                    <MenuItem Header="{x:Static loc:Texts.Menu_TogglePin}" 
                                              Command="{Binding TogglePinCommand}" 
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                              Icon="{DynamicResource {x:Static icons:IconKeys.Lock}}"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid VerticalAlignment="Center">
                                <Grid.InputBindings>
                                    <MouseBinding Gesture="LeftDoubleClick"
                                                  Command="{Binding DataContext.BeginEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Grid.InputBindings>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="IndexText"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="3"
                                           Text="{Binding CompactLabel}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0"
                                           Visibility="Collapsed"/>

                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="NameText"
                                               Grid.Column="0"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding Name}"/>
                                    <Button x:Name="PinIcon"
                                            Grid.Column="1"
                                            Visibility="Collapsed"
                                            Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource IconButtonStyle}"
                                            Width="16" Height="16"
                                            Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding}">
                                        <Viewbox Width="12" Height="12">
                                            <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Lock}}" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                                        </Viewbox>
                                    </Button>
                                    <TextBox x:Name="RenameTextBox"
                                             Grid.Column="0"
                                             Grid.ColumnSpan="2"
                                             loc:FocusExtension.IsFocused="{Binding IsEditing}"
                                             VerticalAlignment="Center"
                                             Visibility="Collapsed"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="0"
                                             Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                             LostKeyboardFocus="RenameTextBox_LostKeyboardFocus"
                                             KeyDown="RenameTextBox_KeyDown"/>
                                </Grid>

                                <Button x:Name="CloseButton"
                                        Grid.Column="2"
                                        Style="{StaticResource CloseIconButtonStyle}"
                                        Width="22"
                                        Height="22"
                                        ToolTip="{x:Static loc:Texts.EffectTab_Remove}"
                                        Command="{Binding DataContext.RemoveTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Viewbox Width="18" Height="18">
                                        <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Close}}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Viewbox>
                                </Button>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True"/>
                                    <Condition Binding="{Binding IsPinned}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="False"/>
                                    <Condition Binding="{Binding IsPinned}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="2"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True"/>
                                    <Condition Binding="{Binding IsPinned}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="2"/>
                            </MultiDataTrigger>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter TargetName="NameText" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="RenameTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="IndexText" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsFirstTab}" Value="True">
                                <Setter TargetName="CloseButton" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                <Setter TargetName="PinIcon" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Button Grid.Column="1"
                Style="{StaticResource AddIconButtonStyle}"
                Margin="6,0,0,4"
                VerticalAlignment="Bottom"
                ToolTip="{x:Static loc:Texts.EffectTab_Add}"
                Command="{Binding AddTabCommand}">
            <Viewbox Width="24" Height="24">
                <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Plus}}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
            </Viewbox>
        </Button>
    </Grid>
</UserControl>