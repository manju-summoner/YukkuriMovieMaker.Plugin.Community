<UserControl x:Class="YukkuriMovieMaker.Plugin.Community.Effect.Video.Container.EffectTabManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:YukkuriMovieMaker.Plugin.Community.Effect.Video.Container"

             xmlns:icons="clr-namespace:YukkuriMovieMaker.Resources.Icons;assembly=YukkuriMovieMaker.Plugin"
             xmlns:c="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Plugin"
             mc:Ignorable="d"
             d:DesignHeight="320" d:DesignWidth="700"
             Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <loc:TabCompactModeConverter x:Key="TabCompactModeConverter"/>

        <ContentControl x:Key="StashMenuItemIcon" x:Shared="False" Content="{DynamicResource {x:Static icons:IconKeys.ArchiveOutline}}" Width="16" Height="16" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
        <ContentControl x:Key="TemplateMenuItemIcon" x:Shared="False" Content="{DynamicResource {x:Static icons:IconKeys.BookmarkOutline}}" Width="16" Height="16" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>

        <Style x:Key="TabListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="TabListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="ToolTip" Value="{Binding Name}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="ToolTip" Value="{x:Null}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ThinScrollBarLineButtonStyle" TargetType="RepeatButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                BorderThickness="1"
                                CornerRadius="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Maximum="{TemplateBinding Maximum}"
                                   Minimum="{TemplateBinding Minimum}"
                                   Value="{TemplateBinding Value}"
                                   ViewportSize="{TemplateBinding ViewportSize}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Style="{StaticResource ThinScrollBarLineButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ThinScrollBarThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Style="{StaticResource ThinScrollBarLineButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="Height" Value="6"/>
                                <Setter Property="MinHeight" Value="6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Opacity" Value="0.55"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ListIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Opacity" Value="0.45"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseIconButtonStyle" TargetType="Button" BasedOn="{StaticResource ListIconButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.HasMultipleTabs, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AddIconSplitButtonStyle" TargetType="{x:Type c:SplitButton}" BasedOn="{StaticResource {x:Type c:SplitButton}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Opacity" Value="0.55"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 右クリックメニューと▼メニュー両方で使う共有 MenuItem。
             ContextMenu は親が排他的なので、x:Shared="False" で各使用箇所に別インスタンスを生成させる。 -->
        <CollectionViewSource x:Key="StashesCollection" Source="{Binding Stashes}"/>

        <MenuItem x:Key="StashesMenuItem" x:Shared="False"
                  Header="{x:Static loc:Texts.Menu_Stashes}"
                  Icon="{DynamicResource {x:Static icons:IconKeys.ArchiveOutline}}"
                  Visibility="{Binding HasStashes, Converter={StaticResource BooleanToVisibilityConverter}}">
            <MenuItem.ItemContainerStyle>
                <Style TargetType="MenuItem">
                    <Setter Property="Header" Value="{Binding}"/>
                    <Setter Property="ToolTip" Value="{Binding ToolTipText}"/>
                    <Setter Property="Command" Value="{Binding DataContext.RestoreStashCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Setter Property="CommandParameter" Value="{Binding}"/>
                    <Setter Property="Template" Value="{DynamicResource StretchMenuItemTemplate}"/>
                    <Setter Property="Icon" Value="{StaticResource StashMenuItemIcon}"/>
                    <Setter Property="HeaderTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <Grid Height="22">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Grid.Column="0" Margin="4,0,12,0" MinWidth="50"/>
                                    <Button Style="{StaticResource ListIconButtonStyle}" Command="{Binding DataContext.RemoveStashCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}" Grid.Column="1" Width="20" Height="20">
                                        <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Close}}" Width="12" Height="12" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </MenuItem.ItemContainerStyle>
            <MenuItem.ItemsSource>
                <CompositeCollection>
                    <MenuItem Header="{x:Static loc:Texts.Menu_ClearStashes}"
                              Click="ClearStashesMenuItem_Click"
                              Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}">
                        <MenuItem.Style>
                            <Style TargetType="MenuItem">
                                <Setter Property="Template" Value="{DynamicResource StretchMenuItemTemplate}"/>
                            </Style>
                        </MenuItem.Style>
                        <MenuItem.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Header, RelativeSource={RelativeSource AncestorType=MenuItem}}" TextDecorations="Underline" Cursor="Hand"/>
                            </DataTemplate>
                        </MenuItem.HeaderTemplate>
                    </MenuItem>
                    <Separator/>
                    <CollectionContainer Collection="{Binding Source={StaticResource StashesCollection}}"/>
                </CompositeCollection>
            </MenuItem.ItemsSource>
        </MenuItem>

        <MenuItem x:Key="TemplatesMenuItem" x:Shared="False"
                  Header="{x:Static loc:Texts.Menu_Templates}"
                  Icon="{DynamicResource {x:Static icons:IconKeys.BookmarkMultipleOutline}}"
                  ItemsSource="{Binding Templates}"
                  Visibility="{Binding HasTemplates, Converter={StaticResource BooleanToVisibilityConverter}}">
            <MenuItem.ItemContainerStyle>
                <Style TargetType="MenuItem">
                    <Setter Property="Header" Value="{Binding}"/>
                    <Setter Property="ToolTip" Value="{Binding ToolTipText}"/>
                    <Setter Property="Command" Value="{Binding DataContext.RestoreTemplateCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Setter Property="CommandParameter" Value="{Binding}"/>
                    <Setter Property="Template" Value="{DynamicResource StretchMenuItemTemplate}"/>
                    <Setter Property="Icon" Value="{StaticResource TemplateMenuItemIcon}"/>
                    <Setter Property="HeaderTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <Grid Height="22" MinWidth="200">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Grid.Column="0" Margin="4,0,12,0"/>
                                    <Button Style="{StaticResource ListIconButtonStyle}" Command="{Binding DataContext.EditTemplateCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}" Grid.Column="1" Width="20" Height="20">
                                        <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Pencil}}" Width="12" Height="12" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </MenuItem.ItemContainerStyle>
        </MenuItem>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0">
            <ListBox x:Name="TabListBox"
                     Style="{StaticResource TabListBoxStyle}"
                     ItemContainerStyle="{StaticResource TabListBoxItemStyle}"
                     ItemsSource="{Binding Tabs}"
                     PreviewMouseWheel="TabListBox_PreviewMouseWheel"
                     SelectedItem="{Binding SelectedTab}">
                <ListBox.ContextMenu>
                    <ContextMenu DataContext="{Binding RelativeSource={RelativeSource Self}, Path=PlacementTarget.DataContext}">
                        <MenuItem Header="{x:Static loc:Texts.Menu_Paste}" Command="{Binding PasteCommand}" Icon="{DynamicResource {x:Static icons:IconKeys.ContentPaste}}"/>
                        <StaticResource ResourceKey="StashesMenuItem"/>
                        <StaticResource ResourceKey="TemplatesMenuItem"/>
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                BorderThickness="1"
                                MinHeight="28"
                                Width="120"
                                Padding="6,0,4,0">
                            <Border.ContextMenu>
                                <ContextMenu DataContext="{Binding RelativeSource={RelativeSource Self}, Path=PlacementTarget.DataContext}">
                                    <ContextMenu.Resources>
                                        <Style TargetType="MenuItem" x:Key="ExtractEffectItemStyle">
                                            <Setter Property="Header" Value="{Binding Name}" />
                                            <Setter Property="Command" Value="{Binding DataContext.Manager.ExtractEffectCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <Setter Property="CommandParameter" Value="{Binding}" />
                                            <Setter Property="Icon" Value="{DynamicResource {x:Static icons:IconKeys.ArrowBottomRight}}" />
                                        </Style>
                                        <Style TargetType="MenuItem" x:Key="ExtractParentItemStyle">
                                            <Setter Property="Header" Value="{Binding Name}" />
                                            <Setter Property="ItemsSource" Value="{Binding ExtractEffects}" />
                                            <Setter Property="ItemContainerStyle" Value="{StaticResource ExtractEffectItemStyle}" />
                                            <Setter Property="Icon" Value="{DynamicResource {x:Static icons:IconKeys.ChevronRight}}" />
                                        </Style>
                                    </ContextMenu.Resources>
                                    <MenuItem Header="{x:Static loc:Texts.Menu_Rename}"
                                              Command="{Binding Manager.BeginEditCommand}"
                                              CommandParameter="{Binding}"
                                              Icon="{DynamicResource {x:Static icons:IconKeys.Pencil}}"/>
                                    <Separator/>
                                    <MenuItem Header="{x:Static loc:Texts.Menu_Copy}"
                                              Command="{Binding Manager.CopyCommand}"
                                              CommandParameter="{Binding}"
                                              Icon="{DynamicResource {x:Static icons:IconKeys.ContentCopy}}"/>
                                    <MenuItem Header="{x:Static loc:Texts.Menu_Paste}"
                                              Command="{Binding Manager.PasteCommand}"
                                              CommandParameter="{Binding}"
                                              Icon="{DynamicResource {x:Static icons:IconKeys.ContentPaste}}"/>
                                    <MenuItem Header="{x:Static loc:Texts.Menu_Duplicate}"
                                              Command="{Binding Manager.DuplicateTabCommand}"
                                              CommandParameter="{Binding}"
                                              Icon="{DynamicResource {x:Static icons:IconKeys.ContentCopy}}"/>
                                    <Separator/>
                                    <MenuItem Header="{x:Static loc:Texts.Menu_Stash}"
                                              Command="{Binding Manager.StashCommand}"
                                              CommandParameter="{Binding}"
                                              Icon="{DynamicResource {x:Static icons:IconKeys.ArchiveArrowDownOutline}}"/>
                                    <MenuItem Header="{x:Static loc:Texts.Menu_Template}"
                                              Command="{Binding Manager.AddTemplateCommand}"
                                              CommandParameter="{Binding}"
                                              Icon="{DynamicResource {x:Static icons:IconKeys.BookmarkOutline}}"/>
                                    <MenuItem Header="{x:Static loc:Texts.Menu_ExtractEffect}"
                                              Icon="{DynamicResource {x:Static icons:IconKeys.TrayArrowDown}}"
                                              Visibility="{Binding Manager.HasExtractEffectSources, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <MenuItem Header="{x:Static loc:Texts.Menu_Stashes}" ItemsSource="{Binding Manager.Stashes}" ItemContainerStyle="{StaticResource ExtractParentItemStyle}" Visibility="{Binding Manager.HasStashes, Converter={StaticResource BooleanToVisibilityConverter}}" Icon="{DynamicResource {x:Static icons:IconKeys.ArchiveOutline}}"/>
                                        <MenuItem Header="{x:Static loc:Texts.Menu_Templates}" ItemsSource="{Binding Manager.Templates}" ItemContainerStyle="{StaticResource ExtractParentItemStyle}" Visibility="{Binding Manager.HasTemplates, Converter={StaticResource BooleanToVisibilityConverter}}" Icon="{DynamicResource {x:Static icons:IconKeys.BookmarkMultipleOutline}}"/>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="{x:Static loc:Texts.EffectTab_Remove}"
                                              Command="{Binding Manager.RemoveTabCommand}"
                                              CommandParameter="{Binding}"
                                              Icon="{DynamicResource {x:Static icons:IconKeys.Delete}}"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid VerticalAlignment="Center">
                                <Grid.InputBindings>
                                    <MouseBinding Gesture="LeftDoubleClick"
                                                  Command="{Binding DataContext.BeginEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                    <MouseBinding MouseAction="MiddleClick"
                                                  Command="{Binding DataContext.RemoveTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Grid.InputBindings>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="IndexText"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="3"
                                           Text="{Binding CompactLabel}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0"
                                           Visibility="Collapsed"/>
                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="NameText"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding Name}"/>
                                    <TextBox x:Name="RenameTextBox"
                                             loc:FocusExtension.IsFocused="{Binding IsEditing}"
                                             VerticalAlignment="Center"
                                             Visibility="Collapsed"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="0"
                                             Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                             LostKeyboardFocus="RenameTextBox_LostKeyboardFocus"
                                             KeyDown="RenameTextBox_KeyDown"/>
                                </Grid>
                                <Button x:Name="CloseButton"
                                        Grid.Column="2"
                                        Style="{StaticResource CloseIconButtonStyle}"
                                        Width="22"
                                        Height="22"
                                        ToolTip="{x:Static loc:Texts.EffectTab_Remove}"
                                        Command="{Binding DataContext.RemoveTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Viewbox Width="18" Height="18">
                                        <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Close}}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Viewbox>
                                </Button>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter TargetName="NameText" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="RenameTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="IndexText" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Value="True">
                                        <Condition.Binding>
                                            <MultiBinding Converter="{StaticResource TabCompactModeConverter}" ConverterParameter="120">
                                                <Binding ElementName="TabListBox" Path="Items.Count"/>
                                                <Binding ElementName="TabListBox" Path="ActualWidth"/>
                                            </MultiBinding>
                                        </Condition.Binding>
                                    </Condition>
                                    <Condition Binding="{Binding IsEditing}" Value="False"/>
                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="MinWidth" Value="28"/>
                                <Setter TargetName="TabBorder" Property="Width" Value="28"/>
                                <Setter TargetName="NameText" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="IndexText" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CloseButton" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="TabBorder" Property="Padding" Value="0"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Value="True">
                                        <Condition.Binding>
                                            <MultiBinding Converter="{StaticResource TabCompactModeConverter}" ConverterParameter="120">
                                                <Binding ElementName="TabListBox" Path="Items.Count"/>
                                                <Binding ElementName="TabListBox" Path="ActualWidth"/>
                                            </MultiBinding>
                                        </Condition.Binding>
                                    </Condition>
                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True"/>
                                    <Condition Binding="{Binding IsEditing}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Width" Value="120"/>
                                <Setter TargetName="NameText" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="IndexText" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="TabBorder" Property="Padding" Value="6,0,4,0"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Value="True">
                                        <Condition.Binding>
                                            <MultiBinding Converter="{StaticResource TabCompactModeConverter}" ConverterParameter="120">
                                                <Binding ElementName="TabListBox" Path="Items.Count"/>
                                                <Binding ElementName="TabListBox" Path="ActualWidth"/>
                                            </MultiBinding>
                                        </Condition.Binding>
                                    </Condition>
                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="CloseButton" Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Column="1">
            <c:SplitButton
                Style="{StaticResource AddIconSplitButtonStyle}"
                Margin="6,0,0,0"
                Height="26" 
                Padding="3"
                VerticalContentAlignment="Center"
                VerticalAlignment="Bottom"
                ToolTip="{x:Static loc:Texts.EffectTab_Add}"
                Command="{Binding AddTabCommand}">
                    <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Plus}}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type c:SplitButton}}}"/>
                    <c:SplitButton.ContextMenu>
                    <ContextMenu DataContext="{Binding RelativeSource={RelativeSource Self}, Path=PlacementTarget.DataContext}">
                        <MenuItem Header="{x:Static loc:Texts.EffectTab_Add}"
                                  Command="{Binding AddTabCommand}"
                                  Icon="{DynamicResource {x:Static icons:IconKeys.Plus}}"/>
                        <MenuItem Header="{x:Static loc:Texts.Menu_Paste}"
                                  Command="{Binding PasteCommand}"
                                  Icon="{DynamicResource {x:Static icons:IconKeys.ContentPaste}}"/>
                        <Separator/>
                        <StaticResource ResourceKey="StashesMenuItem"/>
                        <StaticResource ResourceKey="TemplatesMenuItem"/>
                    </ContextMenu>
                </c:SplitButton.ContextMenu>
            </c:SplitButton>
        </Border>
        </Grid>

        <c:VideoEffectSelector Grid.Row="1" x:Name="EffectSelector"/>
    </Grid>
</UserControl>
