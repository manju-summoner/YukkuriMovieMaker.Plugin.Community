<UserControl x:Class="YukkuriMovieMaker.Plugin.Community.Effect.Video.Container.PresetManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:YukkuriMovieMaker.Plugin.Community.Effect.Video.Container"
             xmlns:vm="clr-namespace:YukkuriMovieMaker.Plugin.Community.Effect.Video.Container"
             xmlns:converters="clr-namespace:YukkuriMovieMaker.Plugin.Community.Effect.Video.Container"
             xmlns:icons="clr-namespace:YukkuriMovieMaker.Resources.Icons;assembly=YukkuriMovieMaker.Plugin"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="700"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>

        <Style x:Key="AnimatedTextBlockStyle" TargetType="TextBlock">
            <Setter Property="MaxWidth" Value="0"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="MaxWidth" To="200" Duration="0:0:0.15" DecelerationRatio="0.9"/>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                <ThicknessAnimation Storyboard.TargetProperty="Margin" To="5,0,5,0" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="MaxWidth" To="0" Duration="0:0:0.15" DecelerationRatio="0.9"/>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                <ThicknessAnimation Storyboard.TargetProperty="Margin" To="0" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Focusable="False" TextElement.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <Style x:Key="VerticalGridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Width" Value="3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="SizeWE"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="Transparent">
                            <Border Width="1" Background="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinScrollBarLineButtonStyle" TargetType="RepeatButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                BorderThickness="1"
                                CornerRadius="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" 
                                   IsDirectionReversed="True"
                                   Maximum="{TemplateBinding Maximum}"
                                   Minimum="{TemplateBinding Minimum}"
                                   Value="{TemplateBinding Value}"
                                   ViewportSize="{TemplateBinding ViewportSize}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Style="{StaticResource ThinScrollBarLineButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ThinScrollBarThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Style="{StaticResource ThinScrollBarLineButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="Height" Value="6"/>
                                <Setter Property="MinHeight" Value="6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border x:Name="RootBorder"
                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1">
            <Grid x:Name="RootControl" SizeChanged="RootControl_SizeChanged">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="GroupColumn" Width="150" MinWidth="120" MaxWidth="400"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" x:Name="GroupPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="GroupListBox" Grid.Row="0" Margin="0"
                             ItemsSource="{Binding Groups}"
                             SelectedItem="{Binding SelectedGroup}"
                             AllowDrop="True"
                             PreviewMouseWheel="ListBox_PreviewMouseWheel"
                             SelectionChanged="ListBox_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="AllowDrop" Value="True"/>
                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="GroupItem_PreviewMouseLeftButtonDown"/>
                                <EventSetter Event="MouseMove" Handler="GroupItem_MouseMove"/>
                                <EventSetter Event="DragEnter" Handler="GroupItem_DragEnter"/>
                                <EventSetter Event="DragLeave" Handler="GroupItem_DragLeave"/>
                                <EventSetter Event="Drop" Handler="GroupItem_Drop"/>
                                <EventSetter Event="MouseDoubleClick" Handler="GroupItem_MouseDoubleClick"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="24" Background="Transparent">
                                    <TextBlock VerticalAlignment="Center" Text="{Binding Name}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox x:Name="GroupRenameTextBox"
                                             Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalAlignment="Center"
                                             Background="Transparent" BorderThickness="1"
                                             LostKeyboardFocus="GroupRenameTextBox_LostKeyboardFocus"
                                             KeyDown="GroupRenameTextBox_KeyDown">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                        <Button Command="{Binding AddGroupCommand}" ToolTip="{x:Static loc:Texts.PresetManager_AddGroup}" Width="28" Height="28" Padding="0" Content="{DynamicResource {x:Static icons:IconKeys.Plus}}"/>
                        <Button Command="{Binding RemoveGroupCommand}" ToolTip="{x:Static loc:Texts.PresetManager_RemoveGroup}" Width="28" Height="28" Padding="0" Content="{DynamicResource {x:Static icons:IconKeys.Minus}}"/>
                    </StackPanel>
                </Grid>

                <GridSplitter x:Name="GroupSplitter" Grid.Column="1" Style="{StaticResource VerticalGridSplitterStyle}" DragCompleted="GridSplitter_DragCompleted"/>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ToggleButton x:Name="MobileMenuButton" Grid.Column="0" VerticalAlignment="Center" Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0" Visibility="Collapsed" Content="{DynamicResource {x:Static icons:IconKeys.Menu}}"/>
                        <Popup x:Name="MobileGroupPopup" PlacementTarget="{Binding ElementName=MobileMenuButton}" Placement="Bottom" StaysOpen="False" IsOpen="{Binding IsChecked, ElementName=MobileMenuButton, Mode=TwoWay}">
                            <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" Width="200" Height="250" Padding="5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <ListBox x:Name="MobileGroupListBox" Grid.Row="0"
                                             ItemsSource="{Binding Groups}"
                                             SelectedItem="{Binding SelectedGroup}"
                                             AllowDrop="True"
                                             PreviewMouseWheel="ListBox_PreviewMouseWheel"
                                             SelectionChanged="ListBox_SelectionChanged">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                <Setter Property="AllowDrop" Value="True"/>
                                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="GroupItem_PreviewMouseLeftButtonDown"/>
                                                <EventSetter Event="MouseMove" Handler="GroupItem_MouseMove"/>
                                                <EventSetter Event="DragEnter" Handler="GroupItem_DragEnter"/>
                                                <EventSetter Event="DragLeave" Handler="GroupItem_DragLeave"/>
                                                <EventSetter Event="Drop" Handler="GroupItem_Drop"/>
                                                <EventSetter Event="MouseDoubleClick" Handler="GroupItem_MouseDoubleClick"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid MinHeight="24" Background="Transparent">
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding Name}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBox x:Name="GroupRenameTextBox"
                                                             Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                                             VerticalAlignment="Center"
                                                             Background="Transparent" BorderThickness="1"
                                                             LostKeyboardFocus="GroupRenameTextBox_LostKeyboardFocus"
                                                             KeyDown="GroupRenameTextBox_KeyDown">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                                        <Button Command="{Binding AddGroupCommand}" ToolTip="{x:Static loc:Texts.PresetManager_AddGroup}" Width="28" Height="28" Padding="0" Content="{DynamicResource {x:Static icons:IconKeys.Plus}}"/>
                                        <Button Command="{Binding RemoveGroupCommand}" ToolTip="{x:Static loc:Texts.PresetManager_RemoveGroup}" Width="28" Height="28" Padding="0" Content="{DynamicResource {x:Static icons:IconKeys.Minus}}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Popup>

                        <Grid Grid.Column="1" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentControl Grid.Column="0"
                                            Content="{DynamicResource {x:Static icons:IconKeys.Magnify}}"
                                            Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                            Width="14" Height="14"
                                            Margin="6,0,4,0"
                                            VerticalAlignment="Center"/>
                            <TextBox x:Name="SearchTextBox" Grid.Column="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Padding="0,6" VerticalContentAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Static loc:Texts.PresetManager_SearchPlaceholder}"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                       IsHitTestVisible="False" VerticalAlignment="Center" Margin="2,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Menu Grid.Column="2" Background="Transparent" VerticalAlignment="Center" Margin="0" Padding="0">
                                <MenuItem Width="28" Height="28" Padding="0" BorderThickness="0" Background="Transparent" ToolTip="{x:Static loc:Texts.SearchMode_Tooltip}">
                                    <MenuItem.Header>
                                        <Grid Width="28" Height="28" Background="Transparent">
                                            <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Tune}}"
                                                            Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                                            Width="16" Height="16"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </MenuItem.Header>
                                    <MenuItem Header="{x:Static loc:Texts.SearchMode_Name}" Command="{Binding SetSearchModeCommand}" CommandParameter="Name">
                                        <MenuItem.Icon>
                                            <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Check}}">
                                                <ContentControl.Style>
                                                    <Style TargetType="ContentControl">
                                                        <Setter Property="Visibility" Value="Hidden"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSearchModeName}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ContentControl.Style>
                                            </ContentControl>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{x:Static loc:Texts.SearchMode_EffectName}" Command="{Binding SetSearchModeCommand}" CommandParameter="EffectName">
                                        <MenuItem.Icon>
                                            <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Check}}">
                                                <ContentControl.Style>
                                                    <Style TargetType="ContentControl">
                                                        <Setter Property="Visibility" Value="Hidden"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSearchModeEffectName}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ContentControl.Style>
                                            </ContentControl>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{x:Static loc:Texts.SearchMode_EffectCount}" Command="{Binding SetSearchModeCommand}" CommandParameter="EffectCount">
                                        <MenuItem.Icon>
                                            <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Check}}">
                                                <ContentControl.Style>
                                                    <Style TargetType="ContentControl">
                                                        <Setter Property="Visibility" Value="Hidden"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSearchModeEffectCount}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ContentControl.Style>
                                            </ContentControl>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{x:Static loc:Texts.SearchMode_RawJson}" Command="{Binding SetSearchModeCommand}" CommandParameter="RawJson">
                                        <MenuItem.Icon>
                                            <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Check}}">
                                                <ContentControl.Style>
                                                    <Style TargetType="ContentControl">
                                                        <Setter Property="Visibility" Value="Hidden"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSearchModeRawJson}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ContentControl.Style>
                                            </ContentControl>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{x:Static loc:Texts.SearchMode_Any}" Command="{Binding SetSearchModeCommand}" CommandParameter="Any">
                                        <MenuItem.Icon>
                                            <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Check}}">
                                                <ContentControl.Style>
                                                    <Style TargetType="ContentControl">
                                                        <Setter Property="Visibility" Value="Hidden"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSearchModeAny}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ContentControl.Style>
                                            </ContentControl>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </MenuItem>
                            </Menu>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="1" Background="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>

                    <ListBox x:Name="PresetListBox" Grid.Row="2" Margin="0"
                             ItemsSource="{Binding DisplayedPresets}"
                             SelectedItem="{Binding SelectedPreset}"
                             SelectionMode="Extended"
                             AllowDrop="True"
                             PreviewMouseWheel="ListBox_PreviewMouseWheel"
                             SelectionChanged="ListBox_SelectionChanged">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{x:Static loc:Texts.Menu_Paste}"
                                          Command="{Binding PlacementTarget.DataContext.PastePresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Icon="{DynamicResource {x:Static icons:IconKeys.ContentPaste}}"/>
                                <Separator/>
                                <MenuItem Header="{x:Static loc:Texts.PresetManager_ExchangeImport}"
                                          Command="{Binding PlacementTarget.DataContext.ImportPresetsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <Separator/>
                                <MenuItem Header="{x:Static loc:Texts.PresetManager_Clear}">
                                    <MenuItem Header="{x:Static loc:Texts.PresetManager_ClearUnselected}"
                                              Command="{Binding PlacementTarget.DataContext.ClearUnselectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </MenuItem>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="AllowDrop" Value="True"/>
                                <Setter Property="Tag" Value="{Binding RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem Header="{x:Static loc:Texts.PresetManager_ApplyPreset}"
                                                      Command="{Binding PlacementTarget.Tag.DataContext.ApplySinglePresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Icon="{DynamicResource {x:Static icons:IconKeys.Check}}"/>
                                            <MenuItem Header="{x:Static loc:Texts.PresetManager_UpdatePreset}"
                                                      Command="{Binding PlacementTarget.Tag.DataContext.UpdatePresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Icon="{DynamicResource {x:Static icons:IconKeys.Update}}"/>
                                            <MenuItem Header="{x:Static loc:Texts.PresetManager_RenamePreset}"
                                                      Command="{Binding PlacementTarget.Tag.DataContext.RenamePresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Icon="{DynamicResource {x:Static icons:IconKeys.Pencil}}"/>
                                            <MenuItem Header="{x:Static loc:Texts.PresetManager_RemovePreset}"
                                                      Command="{Binding PlacementTarget.Tag.DataContext.RemovePresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.Tag.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Icon="{DynamicResource {x:Static icons:IconKeys.Delete}}"/>
                                            <Separator/>
                                            <MenuItem Header="{x:Static loc:Texts.Menu_Copy}"
                                                      Command="{Binding PlacementTarget.Tag.DataContext.CopyPresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.Tag.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Icon="{DynamicResource {x:Static icons:IconKeys.ContentCopy}}"/>
                                            <MenuItem Header="{x:Static loc:Texts.Menu_Cut}"
                                                      Command="{Binding PlacementTarget.Tag.DataContext.CutPresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.Tag.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Icon="{DynamicResource {x:Static icons:IconKeys.ContentCut}}"/>
                                            <MenuItem Header="{x:Static loc:Texts.Menu_Paste}"
                                                      Command="{Binding PlacementTarget.Tag.DataContext.PastePresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Icon="{DynamicResource {x:Static icons:IconKeys.ContentPaste}}"/>
                                            <Separator/>
                                            <MenuItem Header="{x:Static loc:Texts.PresetManager_ClearPreset}"
                                                      Command="{Binding PlacementTarget.Tag.DataContext.ClearPresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <Separator/>
                                            <MenuItem Header="{x:Static loc:Texts.PresetManager_ExchangeExport}"
                                                      Command="{Binding PlacementTarget.Tag.DataContext.ExportPresetsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.Tag.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Icon="{DynamicResource {x:Static icons:IconKeys.Export}}"/>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="PresetItem_PreviewMouseLeftButtonDown"/>
                                <EventSetter Event="MouseMove" Handler="PresetItem_MouseMove"/>
                                <EventSetter Event="DragEnter" Handler="PresetItem_DragEnter"/>
                                <EventSetter Event="DragLeave" Handler="PresetItem_DragLeave"/>
                                <EventSetter Event="Drop" Handler="PresetItem_Drop"/>
                                <EventSetter Event="MouseDoubleClick" Handler="PresetItem_MouseDoubleClick"/>
                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="PresetItem_PreviewMouseRightButtonDown"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="24" Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource StarButtonStyle}"
                                            Width="24" Height="24" Padding="0" Margin="0,0,4,0">
                                        <Grid Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.StarOutline}}"
                                                            Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}">
                                                <ContentControl.Style>
                                                    <Style TargetType="ContentControl">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ContentControl.Style>
                                            </ContentControl>
                                            
                                            <Path Data="M12,17.27L18.18,21L16.54,13.97L22,9.24L14.81,8.62L12,2L9.19,8.62L2,9.24L7.45,13.97L5.82,21L12,17.27Z"
                                                  Fill="#FFD700" Stretch="Uniform">
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                        </Grid>
                                    </Button>

                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding Name}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox x:Name="PresetRenameTextBox"
                                             Grid.Column="1"
                                             Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalAlignment="Center"
                                             Background="Transparent" BorderThickness="1"
                                             LostKeyboardFocus="PresetRenameTextBox_LostKeyboardFocus"
                                             KeyDown="PresetRenameTextBox_KeyDown">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding EffectCount}"
                                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>

                                    <Border Grid.Column="3" Width="16" Height="16" Background="Transparent"
                                            VerticalAlignment="Center" Margin="0,0,4,0" Cursor="Help">
                                        <Border.ToolTip>
                                            <ToolTip Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                                                     Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                                     BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                                     BorderThickness="1"
                                                     Placement="Right"
                                                     HasDropShadow="False">
                                                <TextBlock Text="{Binding EffectInfo}"
                                                           LineHeight="17"
                                                           FontFamily="Consolas"
                                                           TextWrapping="NoWrap"/>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.InformationOutline}}"
                                                        Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                                        Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="3" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                            <Button Command="{Binding AddPresetCommand}" Padding="0" Height="28" MinWidth="28" ToolTip="{x:Static loc:Texts.PresetManager_AddPreset}" HorizontalContentAlignment="Left" VerticalContentAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Width="28">
                                        <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Plus}}" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Grid>
                                    <TextBlock Grid.Column="1" Text="{x:Static loc:Texts.PresetManager_AddPreset}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Style="{StaticResource AnimatedTextBlockStyle}" />
                                </Grid>
                            </Button>
                            <Button Command="{Binding RemovePresetCommand}" CommandParameter="{Binding SelectedItems, ElementName=PresetListBox}" Padding="0" Height="28" MinWidth="28" ToolTip="{x:Static loc:Texts.PresetManager_RemovePreset}" HorizontalContentAlignment="Left" VerticalContentAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Width="28">
                                        <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Minus}}" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Grid>
                                    <TextBlock Grid.Column="1" Text="{x:Static loc:Texts.PresetManager_RemovePreset}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Style="{StaticResource AnimatedTextBlockStyle}" />
                                </Grid>
                            </Button>
                            <Button Command="{Binding UpdatePresetCommand}" Padding="0" Height="28" MinWidth="28" ToolTip="{x:Static loc:Texts.PresetManager_UpdatePreset}" HorizontalContentAlignment="Left" VerticalContentAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Width="28">
                                        <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Update}}" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Grid>
                                    <TextBlock Grid.Column="1" Text="{x:Static loc:Texts.PresetManager_UpdatePreset}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Style="{StaticResource AnimatedTextBlockStyle}" />
                                </Grid>
                            </Button>
                            <Button Command="{Binding ApplyPresetCommand}" CommandParameter="{Binding SelectedItems, ElementName=PresetListBox}" Padding="0" Height="28" MinWidth="28" FontWeight="Bold" ToolTip="{x:Static loc:Texts.PresetManager_ApplyPreset}" HorizontalContentAlignment="Left" VerticalContentAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Width="28">
                                        <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Check}}" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Grid>
                                    <TextBlock Grid.Column="1" Text="{x:Static loc:Texts.PresetManager_ApplyPreset}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Style="{StaticResource AnimatedTextBlockStyle}" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Thumb Grid.Row="1" Height="6" Cursor="SizeNS" Margin="5,0,5,5"
               DragDelta="Thumb_DragDelta"
               DragCompleted="Thumb_DragCompleted">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="Transparent">
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1"/>
                                <RowDefinition Height="2"/>
                                <RowDefinition Height="1"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Width="30" Background="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>
                            <Border Grid.Row="2" Width="30" Background="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
    </Grid>
</UserControl>