<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:YukkuriMovieMaker.Plugin.Community.Effect.Video.GradientMap.Converters"
                    xmlns:loc="clr-namespace:YukkuriMovieMaker.Plugin.Community.Effect.Video.GradientMap.Localization">

    <conv:GrdExtensionToVisibilityConverter x:Key="GrdExtToVis"/>

    <!--
        .grd ファイルのときに右端に「GRD」バッジを表示する DataTemplate。
        FileSelector.TrailingContentTemplate に渡して使う。
        DataContext は FileSelector.FileItem（FilePath / FileName / IsFavorite など）。
    -->
    <DataTemplate x:Key="GrdBadgeTemplate">
        <Border Visibility="{Binding FilePath, Converter={StaticResource GrdExtToVis}}"
                Background="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"
                Padding="4,1"
                Margin="2,0,6,0"
                VerticalAlignment="Center"
                ToolTip="{x:Static loc:Texts.GrdFileTooltip}">
            <TextBlock Text="GRD"
                       Foreground="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"
                       FontSize="9"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </Border>
    </DataTemplate>
</ResourceDictionary>
