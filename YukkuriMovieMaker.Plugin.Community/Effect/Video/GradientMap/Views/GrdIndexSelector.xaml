<UserControl x:Class="YukkuriMovieMaker.Plugin.Community.Effect.Video.GradientMap.Views.GrdIndexSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:YukkuriMovieMaker.Plugin.Community.Effect.Video.GradientMap.Converters"
             Name="root"
             Height="26">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>

        <DataTemplate x:Key="SelectedEntryTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Width="32" Height="14"
                        Margin="0,0,4,0"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                        BorderThickness="1"
                        Visibility="{Binding Thumbnail, Converter={StaticResource NullToVis}}"
                        VerticalAlignment="Center">
                    <Image Source="{Binding Thumbnail}"
                           Stretch="Fill"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
                <TextBlock Grid.Column="1"
                           Text="{Binding Name}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="DropdownEntryTemplate">
            <Grid Height="52">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Width="90" Height="40"
                        Margin="4,0,4,0"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                        BorderThickness="1"
                        VerticalAlignment="Center">
                    <Image Source="{Binding Thumbnail}"
                           Stretch="Fill"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="4,0,6,0">
                    <TextBlock Text="{Binding Index, StringFormat={}#{0}}"
                               Opacity="0.7"
                               FontSize="10"/>
                    <TextBlock Text="{Binding Name}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <conv:GrdEntryTemplateSelector x:Key="TemplateSelector"
                                       SelectedTemplate="{StaticResource SelectedEntryTemplate}"
                                       DropdownTemplate="{StaticResource DropdownEntryTemplate}"/>
    </UserControl.Resources>

    <Grid Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
        <ComboBox x:Name="GrdComboBox"
                  ItemsSource="{Binding Entries}"
                  SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                  ItemTemplateSelector="{StaticResource TemplateSelector}"
                  VerticalContentAlignment="Center"
                  MaxDropDownHeight="320">
            <ComboBox.Style>
                <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                    <Style.Triggers>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ComboBox.Style>
            <ComboBox.ItemContainerStyle>
                <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ComboBox.ItemContainerStyle>
        </ComboBox>
    </Grid>
</UserControl>
