<UserControl x:Class="YukkuriMovieMaker.Plugin.Community.Voice.IrodoriTTS.IrodoriTTSSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:YukkuriMovieMaker.Plugin.Community.Voice.IrodoriTTS"
             xmlns:c="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Plugin"
             xmlns:ps="clr-namespace:YukkuriMovieMaker.Settings;assembly=YukkuriMovieMaker.Plugin"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.DataContext>
        <local:IrodoriTTSSettingsViewModel/>
    </UserControl.DataContext>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Grid.IsSharedSizeScope="True">
        <!-- Local Settings -->
        <Expander Header="{x:Static local:Texts.LocalSettings}" IsExpanded="True">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="{x:Static local:Texts.GradioAppPath}" VerticalContentAlignment="Center"/>
                    <c:FileSelector Grid.Row="0" Grid.Column="1"
                                    FilterName="gradio_app.py" Filter="gradio_app.py" FileType="None"
                                    Value="{Binding Source={x:Static local:IrodoriTTSSettings.Default}, Path=GradioAppPath}"
                                    MaxWidth="200" HorizontalAlignment="Right"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="{x:Static local:Texts.ServerPort}" VerticalContentAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding Source={x:Static local:IrodoriTTSSettings.Default}, Path=ServerPort, UpdateSourceTrigger=PropertyChanged, Delay=1}"
                             VerticalContentAlignment="Center" Width="200" HorizontalAlignment="Right"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="{x:Static local:Texts.ShowConsoleWindow}" VerticalContentAlignment="Center"/>
                    <c:ToggleSlider Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right"
                                    Value="{Binding Source={x:Static local:IrodoriTTSSettings.Default}, Path=ShowConsoleWindow}"/>
                </Grid>
                <GroupBox Header="{x:Static local:Texts.AboutIrodoriTTS}" Margin="6">
                    <TextBlock Margin="6" TextWrapping="Wrap">
                        <Run Text="{x:Static local:Texts.AboutIrodoriTTSMessage}"/>
                        <LineBreak/>
                        <LineBreak/>
                        <Hyperlink Command="{Binding Source={x:Static ps:CommandSettings.Default},Path=[OpenUri]}" CommandParameter="https://manjubox.net/ymm4/faq/%E3%82%86%E3%81%A3%E3%81%8F%E3%82%8A%E3%83%9C%E3%82%A4%E3%82%B9/Irodori-TTS/">
                            <Run Text="{x:Static local:Texts.HelpLinkText}"/>
                        </Hyperlink>
                        <LineBreak/>
                        <LineBreak/>
                        <Run Text="©2026 Aratako"/>
                    </TextBlock>
                </GroupBox>
            </StackPanel>
        </Expander>

        <!-- Server Settings -->
        <Expander Header="{x:Static local:Texts.ServerSettings}" IsExpanded="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="{x:Static local:Texts.TTSUrl}" VerticalContentAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding Source={x:Static local:IrodoriTTSSettings.Default}, Path=TTSUrl, UpdateSourceTrigger=PropertyChanged, Delay=1}"
                         VerticalContentAlignment="Center"
                         Width="200"
                         HorizontalAlignment="Right"/>

                <Label Grid.Row="1" Grid.Column="0" Content="{x:Static local:Texts.VoiceDesignUrl}" VerticalContentAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding Source={x:Static local:IrodoriTTSSettings.Default}, Path=VoiceDesignUrl, UpdateSourceTrigger=PropertyChanged, Delay=1}"
                         VerticalContentAlignment="Center"
                         Width="200"
                         HorizontalAlignment="Right"/>
            </Grid>
        </Expander>

        <!-- Reference Voice Management -->
        <Expander Header="{x:Static local:Texts.RefVoiceManagement}" IsExpanded="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="120"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          ItemsSource="{Binding RefVoiceItems}"
                          SelectedItem="{Binding SelectedRefVoice}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          MaxHeight="300">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static local:Texts.SourceApp}" Binding="{Binding SourceApplication}" Width="Auto"/>
                        <DataGridTextColumn Header="{x:Static local:Texts.NameColumn}" Binding="{Binding Name}" Width="Auto"/>
                        <DataGridTextColumn Header="{x:Static local:Texts.CaptionColumn}" Binding="{Binding Caption}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{x:Static local:Texts.CreateNew}" Command="{Binding CreateNewCommand}" Width="100" Height="26"/>
                    <Button Content="{x:Static local:Texts.Delete}" Command="{Binding DeleteRefVoiceCommand}" Width="100" Height="26"/>
                    <Button Content="{x:Static local:Texts.Preview}" Command="{Binding PreviewRefVoiceCommand}" Width="100" Height="26"/>
                </StackPanel>
            </Grid>
        </Expander>
    </StackPanel>
    </ScrollViewer>
</UserControl>
