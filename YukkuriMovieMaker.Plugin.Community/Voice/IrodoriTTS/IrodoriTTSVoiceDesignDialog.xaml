<Window x:Class="YukkuriMovieMaker.Plugin.Community.Voice.IrodoriTTS.IrodoriTTSVoiceDesignDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:YukkuriMovieMaker.Plugin.Community.Voice.IrodoriTTS"
        xmlns:c="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Plugin"
        Title="{x:Static local:Texts.VoiceDesignSection}"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" SizeToContent="Height" Style="{StaticResource {x:Type Window}}">
    <Window.DataContext>
        <local:IrodoriTTSVoiceDesignDialogViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="26"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="{x:Static local:Texts.SpeakerName}" VerticalContentAlignment="Center"/>
        <Grid Grid.Row="0" Grid.Column="1">
            <TextBox x:Name="speakerNameTextBox"
                     Text="{Binding SpeakerName, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center" Width="200" HorizontalAlignment="Right"
                     Padding="4"/>
            <TextBlock Text="{x:Static local:Texts.SpeakerNamePlaceholder}" VerticalAlignment="Center" HorizontalAlignment="Right" Width="200" Margin="4,0,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextBoxStyleBase}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SpeakerName}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ElementName=speakerNameTextBox,Path=IsFocused}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <Label Grid.Row="1" Grid.Column="0" Content="{x:Static local:Texts.Caption}" VerticalContentAlignment="Center"/>
        <Grid Grid.Row="1" Grid.Column="1">
            <TextBox x:Name="captionTextBox"
                     Text="{Binding Caption, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" ToolTip="{x:Static local:Texts.CaptionDesc}"
                     Padding="4"/>
            <TextBlock Text="{x:Static local:Texts.CaptionPlaceholder}" Margin="4,4,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextBoxStyleBase}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Caption}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ElementName=captionTextBox,Path=IsFocused}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <Label Grid.Row="2" Grid.Column="0" Content="{x:Static local:Texts.SpeechText}" VerticalContentAlignment="Center"/>
        <Grid Grid.Row="2" Grid.Column="1">
            <TextBox x:Name="speechTextTextBox"
                     Text="{Binding SpeechText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" ToolTip="{x:Static local:Texts.SpeechTextDesc}"
                     Padding="4"/>
            <TextBlock Text="{x:Static local:Texts.SpeechTextPlaceholder}" Margin="4,4,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextBoxStyleBase}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SpeechText}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ElementName=speechTextTextBox,Path=IsFocused}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <Label Grid.Row="3" Grid.Column="0" Content="{x:Static local:Texts.NumStepsName}" VerticalContentAlignment="Center"/>
        <c:TextBoxSlider Grid.Row="3" Grid.Column="1"
                         Value="{Binding NumSteps}" Min="1" Max="120" DefaultMin="1" DefaultMax="120"
                         Unit="" Width="200" HorizontalAlignment="Right"/>

        <Label Grid.Row="4" Grid.Column="0" Content="{x:Static local:Texts.Seed}" VerticalContentAlignment="Center"/>
        <TextBox Grid.Row="4" Grid.Column="1"
                 Text="{Binding Seed, UpdateSourceTrigger=PropertyChanged}"
                 VerticalContentAlignment="Center" Width="200" HorizontalAlignment="Right"
                 Padding="4"/>

        <Label Grid.Row="5" Grid.Column="0" Content="{x:Static local:Texts.Checkpoint}" VerticalContentAlignment="Center"
               ToolTip="{x:Static local:Texts.CheckpointDesc}"/>
        <c:FileSelector Grid.Row="5" Grid.Column="1"
                        FileType="None"
                        Value="{Binding Checkpoint}"
                        Width="200" HorizontalAlignment="Right"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding ErrorText}" Foreground="Red"
                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="6" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Height="26">
            <Button Command="{Binding GenerateCommand}" Width="100">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Content" Value="{x:Static local:Texts.Generate}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsGenerating}" Value="True">
                                <Setter Property="Content" Value="{x:Static local:Texts.Generating}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Command="{Binding PreviewCommand}" Width="100">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Content" Value="{x:Static local:Texts.Preview}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                <Setter Property="Content" Value="{x:Static local:Texts.Stop}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Command="{Binding SaveCommand}" Width="100">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Content" Value="{x:Static local:Texts.Save}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                <Setter Property="Content" Value="{x:Static local:Texts.Saving}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
