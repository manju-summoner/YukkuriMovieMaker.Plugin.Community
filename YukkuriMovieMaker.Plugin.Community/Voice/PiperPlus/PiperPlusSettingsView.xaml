<UserControl x:Class="YukkuriMovieMaker.Plugin.Community.Voice.PiperPlus.PiperPlusSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:YukkuriMovieMaker.Plugin.Community.Voice.PiperPlus"
             xmlns:ps="clr-namespace:YukkuriMovieMaker.Settings;assembly=YukkuriMovieMaker.Plugin"
             xmlns:c="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Controls"
             xmlns:icons="clr-namespace:YukkuriMovieMaker.Resources.Icons;assembly=YukkuriMovieMaker.Plugin"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Expander Grid.Row="0" Header="Piper Plus" IsExpanded="True">
            <StackPanel>
                <Grid>
                    <Label Content="{x:Static local:Texts.ModelDirectory}"/>
                    <c:DirectorySelector
                        Value="{Binding Source={x:Static local:PiperPlusSettings.Default}, Path=ModelDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Width="300"
                        HorizontalAlignment="Right"/>
                </Grid>
                <Grid>
                    <Label Content="{x:Static local:Texts.BinaryDirectory}"/>
                    <c:DirectorySelector
                        Value="{Binding Source={x:Static local:PiperPlusSettings.Default}, Path=BinaryDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Width="300"
                        HorizontalAlignment="Right"/>
                </Grid>
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                        <TextBlock Text="{Binding VersionText}" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUpdate}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button MinWidth="60" Height="26" Padding="6,0"
                                Content="{Binding UpdateDescription}"
                                Command="{Binding UpdateCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUpdate}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding SpeakerCountText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Button Width="26" Command="{Binding RefreshCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Content" Value="{DynamicResource {x:Static icons:IconKeys.Refresh}}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Content" Value="{DynamicResource {x:Static icons:IconKeys.LoadingAnimation}}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>

                <Expander Header="{x:Static local:Texts.ModelList}" IsExpanded="True">
                    <DataGrid ItemsSource="{Binding Models}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              IsReadOnly="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              MinHeight="60"
                              MaxHeight="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{x:Static local:Texts.ModelDisplayName}"
                                                Binding="{Binding DisplayName, UpdateSourceTrigger=LostFocus}"
                                                Width="*"/>
                            <DataGridTextColumn Header="{x:Static local:Texts.ModelInternalName}"
                                                Binding="{Binding ModelName, Mode=OneWay}"
                                                Width="*"
                                                IsReadOnly="True"/>
                            <DataGridTextColumn Header="{x:Static local:Texts.ModelSpeakerCount}"
                                                Binding="{Binding NumSpeakers, Mode=OneWay}"
                                                Width="80"
                                                IsReadOnly="True"/>
                            <DataGridTextColumn Header="{x:Static local:Texts.ModelLanguage}"
                                                Binding="{Binding LanguageCodes, Mode=OneWay}"
                                                Width="120"
                                                IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Expander>

                <Expander Header="{x:Static local:Texts.PretrainedModelList}" IsExpanded="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <ListBox Grid.Row="0"
                                     x:Name="PretrainedListBox"
                                     ItemsSource="{Binding PretrainedModels}"
                                     DisplayMemberPath="DisplayName"
                                     SelectedIndex="0"/>
                        </Grid>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="26"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0"
                                   Content="{x:Static local:Texts.PretrainedModelLanguages}"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Text="{Binding ElementName=PretrainedListBox, Path=SelectedItem.Languages, Mode=OneWay}"
                                     IsReadOnly="True"
                                     VerticalContentAlignment="Center"/>

                            <Label Grid.Row="1" Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Content="{x:Static local:Texts.PretrainedModelDescription}"/>
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Text="{Binding ElementName=PretrainedListBox, Path=SelectedItem.Description, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Center"/>

                            <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                    Command="{Binding ElementName=PretrainedListBox, Path=SelectedItem.DownloadCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Content" Value="{x:Static local:Texts.PretrainedModelDownload}"/>
                                        <Setter Property="IsEnabled" Value="True"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=PretrainedListBox, Path=SelectedItem.IsDownloaded}" Value="True">
                                                <Setter Property="Content" Value="{x:Static local:Texts.PretrainedModelDownloaded}"/>
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ElementName=PretrainedListBox, Path=SelectedItem.IsDownloading}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <ProgressBar Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                         Value="{Binding ElementName=PretrainedListBox, Path=SelectedItem.ProgressValue, Mode=OneWay}"
                                         Minimum="0" Maximum="1"
                                         VerticalAlignment="Stretch">
                                <ProgressBar.Style>
                                    <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=PretrainedListBox, Path=SelectedItem.IsDownloading}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ProgressBar.Style>
                            </ProgressBar>
                        </Grid>
                    </Grid>
                </Expander>

                <GroupBox Header="{x:Static local:Texts.AboutPiperPlus}" Margin="6" Padding="12,6,12,6">
                    <TextBlock Margin="6" TextWrapping="Wrap">
                        <Run Text="{x:Static local:Texts.AboutPiperPlusDescription}"/>
                        <LineBreak/>
                        <Run Text="{x:Static local:Texts.AboutPiperPlusHowTo}"/>
                        <LineBreak/>
                        <Run Text="{x:Static local:Texts.AboutPiperPlusBinaryNote}"/>
                        <LineBreak/>
                        <LineBreak/>
                        <Hyperlink Command="{Binding Source={x:Static ps:CommandSettings.Default}, Path=[OpenUri]}" CommandParameter="https://github.com/ayutaz/piper-plus">
                            <Run Text="{x:Static local:Texts.AboutPiperPlusLink}"/>
                        </Hyperlink>
                        <LineBreak/>
                        <LineBreak/>
                        <Run Text="Copyright (c) 2022 Michael Hansen"/>
                        <LineBreak/>
                        <Run Text="Copyright (c) 2025 ayutaz"/>
                    </TextBlock>
                </GroupBox>
            </StackPanel>
        </Expander>

        <Grid Grid.Row="1" Height="26">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsProgressVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <ProgressBar Value="{Binding ProgressValue, Mode=OneWay}"
                         Minimum="0" Maximum="1"/>
            <TextBlock Text="{Binding ProgressMessage}"
                       VerticalAlignment="Center"
                       Margin="6,0,0,0"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Grid>
    </Grid>
</UserControl>
