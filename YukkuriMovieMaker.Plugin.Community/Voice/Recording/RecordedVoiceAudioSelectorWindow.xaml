<Window x:Class="YukkuriMovieMaker.Plugin.Community.Voice.Recording.RecordedVoiceAudioSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:YukkuriMovieMaker.Plugin.Community.Voice.Recording"
        xmlns:icons="clr-namespace:YukkuriMovieMaker.Resources.Icons;assembly=YukkuriMovieMaker.Plugin"
        Title="{x:Static local:Texts.RecordedAudioSelectorTitle}"
        Width="560"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,6" Text="{x:Static local:Texts.RecordedAudioSelectorHint}"/>

        <DockPanel Grid.Row="1" Margin="0,0,0,6" LastChildFill="True">
            <Button DockPanel.Dock="Right"
                    Margin="6,0,0,0"
                    Width="32"
                    Padding="0"
                    Content="{DynamicResource {x:Static icons:IconKeys.FolderOpen}}"
                    ToolTip="{x:Static local:Texts.ChangeFolder}"
                    Click="OnChangeFolderClicked"/>
            <TextBlock VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding RecordsDirectory}"
                       Text="{Binding RecordsDirectory}"/>
        </DockPanel>

        <ListView Grid.Row="2"
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}"
                  MouseDoubleClick="OnListViewMouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="{x:Static local:Texts.RecordedAudioFileNameHeader}" Width="260" DisplayMemberBinding="{Binding FileName}"/>
                    <GridViewColumn Header="{x:Static local:Texts.RecordedAudioCreatedAtHeader}" Width="170" DisplayMemberBinding="{Binding CreatedAtText}"/>
                    <GridViewColumn Header="{x:Static local:Texts.RecordedAudioDurationHeader}" Width="90" DisplayMemberBinding="{Binding DurationText}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <DockPanel Grid.Row="3" Margin="0,8,0,0">
            <Button DockPanel.Dock="Left" Margin="0,0,6,0" MinWidth="84" Height="26" Content="{x:Static local:Texts.PlaySelected}" Click="OnPreviewClicked"/>
            <Button DockPanel.Dock="Left" Margin="0,0,6,0" MinWidth="84" Height="26" Content="{x:Static local:Texts.Unselect}" Click="OnUnselectClicked"/>
            <Button DockPanel.Dock="Right" Margin="6,0,0,0" MinWidth="84" Height="26" Content="{x:Static local:Texts.Cancel}" IsCancel="True"/>
            <Button DockPanel.Dock="Right" MinWidth="84" Height="26" Content="{x:Static local:Texts.Select}" IsDefault="True" Click="OnSelectClicked"/>
        </DockPanel>
    </Grid>
</Window>
