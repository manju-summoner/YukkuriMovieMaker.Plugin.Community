<UserControl x:Class="YukkuriMovieMaker.Plugin.Community.FileSource.Audio.MIDI.Views.MidiSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:YukkuriMovieMaker.Plugin.Community.FileSource.Audio.MIDI.ViewModels"
             xmlns:loc="clr-namespace:YukkuriMovieMaker.Plugin.Community.FileSource.Audio.MIDI.Localization"
             xmlns:c="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Controls"
             mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="500">
    <UserControl.DataContext>
        <vm:MidiSettingsViewModel/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4">

            <Border Background="{DynamicResource {x:Static SystemColors.InfoBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="1" Padding="6,4" Margin="0,0,0,4"
                    Visibility="{Binding HasNoSoundFonts, Converter={StaticResource BoolVis}}">
                <TextBlock Text="{x:Static loc:Texts.DownloadSoundFont}"
                           Foreground="{DynamicResource {x:Static SystemColors.InfoTextBrushKey}}"/>
            </Border>

            <Expander Header="{x:Static loc:Texts.AudioSettings}" IsExpanded="True" Margin="0,2">
                <StackPanel Margin="8,4">
                    <Grid Margin="0,2">
                        <Label Content="{x:Static loc:Texts.SampleRate}" VerticalAlignment="Center"/>
                        <ComboBox Width="120" HorizontalAlignment="Right" VerticalAlignment="Center" Height="24"
                                  SelectedValue="{Binding Audio.SampleRate, Mode=TwoWay}"
                                  SelectedValuePath="Content">
                            <ComboBoxItem>22050</ComboBoxItem>
                            <ComboBoxItem>44100</ComboBoxItem>
                            <ComboBoxItem>48000</ComboBoxItem>
                        </ComboBox>
                    </Grid>
                    <Grid Margin="0,2">
                        <Label Content="{x:Static loc:Texts.MasterVolume}" VerticalAlignment="Center"/>
                        <c:TextBoxSlider Value="{Binding Audio.MasterVolume, Mode=TwoWay}"
                                         Min="0" Max="2" DefaultMin="0.5" DefaultMax="1.5" Delta="0.05"
                                         StringFormat="F2" Unit="×" Width="200"
                                         HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Label Content="{x:Static loc:Texts.EnableNormalization}" VerticalAlignment="Center"/>
                        <c:ToggleSlider Value="{Binding Audio.EnableNormalization, Mode=TwoWay}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Expander>

            <Expander Header="{x:Static loc:Texts.PerformanceSettings}" IsExpanded="True" Margin="0,2">
                <StackPanel Margin="8,4">
                    <Grid Margin="0,2">
                        <Label Content="{x:Static loc:Texts.RenderingMode}" VerticalAlignment="Center"/>
                        <ComboBox Width="200" HorizontalAlignment="Right" VerticalAlignment="Center" Height="24"
                                  SelectedValue="{Binding Performance.RenderingMode, Mode=TwoWay}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Tag="SoundFont" Content="{x:Static loc:Texts.RenderingModeSoundFont}"/>
                            <ComboBoxItem Tag="Synthesis" Content="{x:Static loc:Texts.RenderingModeSynthesis}"/>
                        </ComboBox>
                    </Grid>
                    <Grid Margin="0,2">
                        <Label Content="{x:Static loc:Texts.BufferSize}" VerticalAlignment="Center"/>
                        <c:TextBoxSlider Value="{Binding Performance.BufferSize, Mode=TwoWay}"
                                         Min="256" Max="8192" DefaultMin="512" DefaultMax="2048" Delta="256"
                                         StringFormat="F0" Unit="" Width="200"
                                         HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Label Content="{x:Static loc:Texts.MaxPolyphony}" VerticalAlignment="Center"/>
                        <c:TextBoxSlider Value="{Binding Performance.MaxPolyphony, Mode=TwoWay}"
                                         Min="16" Max="512" DefaultMin="64" DefaultMax="256" Delta="16"
                                         StringFormat="F0" Unit="" Width="200"
                                         HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Label Content="{x:Static loc:Texts.EnableGpuAcceleration}" VerticalAlignment="Center"/>
                        <c:ToggleSlider Value="{Binding Performance.EnableGpuAcceleration, Mode=TwoWay}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Expander>

            <Expander Header="{x:Static loc:Texts.SoundFontSettings}" IsExpanded="True" Margin="0,2">
                <StackPanel Margin="8,4">
                    <Grid Margin="0,2">
                        <Label Content="{x:Static loc:Texts.EnableSoundFont}" VerticalAlignment="Center"/>
                        <c:ToggleSlider Value="{Binding SoundFont.EnableSoundFont, Mode=TwoWay}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Label Content="{x:Static loc:Texts.FallbackToSynthesis}" VerticalAlignment="Center"/>
                        <c:ToggleSlider Value="{Binding SoundFont.FallbackToSynthesis, Mode=TwoWay}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Separator Margin="0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Button Content="{x:Static loc:Texts.DownloadSoundFont}"
                                Command="{Binding DownloadSoundFontCommand}"
                                Height="26" Padding="8,0"
                                IsEnabled="{Binding HasNoSoundFonts}"/>
                        <Button Content="{x:Static loc:Texts.OpenSoundFontFolder}"
                                Command="{Binding OpenSoundFontFolderCommand}"
                                Height="26" Padding="8,0"/>
                    </StackPanel>
                    <Grid Margin="0,2" Visibility="{Binding IsDownloading, Converter={StaticResource BoolVis}}">
                        <ProgressBar Height="12" Value="{Binding DownloadProgress, Mode=OneWay}" Maximum="100"/>
                    </Grid>
                    <TextBlock Text="{Binding DownloadStatus}" Margin="0,2" FontSize="11"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                    <Separator Margin="0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="{x:Static loc:Texts.LayerEnabled}" FontWeight="SemiBold" Padding="2"/>
                        <Label Grid.Column="1" Content="{x:Static loc:Texts.LayerFileName}" FontWeight="SemiBold" Padding="2"/>
                        <Label Grid.Column="2" Content="{x:Static loc:Texts.LayerVolume}" FontWeight="SemiBold" Padding="2"/>
                    </Grid>
                    <ListBox ItemsSource="{Binding SoundFont.Layers}"
                             SelectedItem="{Binding SelectedLayer, Mode=TwoWay}"
                             MaxHeight="200" BorderThickness="1"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="28">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <c:ToggleSlider Grid.Column="0"
                                                    Value="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              IsEditable="True" Height="22" Margin="2,0"
                                              VerticalAlignment="Center"
                                              Text="{Binding FileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding DataContext.InstalledSoundFonts, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              MaxDropDownHeight="160"/>
                                    <c:TextBoxSlider Grid.Column="2"
                                                     Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Min="0" Max="2" DefaultMin="0.5" DefaultMax="1.5" Delta="0.05"
                                                     StringFormat="F2" Unit="×" Margin="2,0"
                                                     VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0">
                        <Button Content="{x:Static loc:Texts.AddLayer}"
                                Command="{Binding AddLayerCommand}"
                                Height="24" Padding="8,0"/>
                        <Button Content="{x:Static loc:Texts.RemoveLayer}"
                                Command="{Binding RemoveLayerCommand}"
                                Height="24" Padding="8,0"/>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <Expander Header="{x:Static loc:Texts.EffectsSettings}" IsExpanded="False" Margin="0,2">
                <StackPanel Margin="8,4">
                    <Grid Margin="0,2">
                        <Label Content="{x:Static loc:Texts.EnableEffects}" VerticalAlignment="Center"/>
                        <c:ToggleSlider Value="{Binding Effects.EnableEffects, Mode=TwoWay}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Label Content="{x:Static loc:Texts.EnableLimiter}" VerticalAlignment="Center"/>
                        <c:ToggleSlider Value="{Binding Effects.EnableLimiter, Mode=TwoWay}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Label Content="{x:Static loc:Texts.LimiterThreshold}" VerticalAlignment="Center"/>
                        <c:TextBoxSlider Value="{Binding Effects.LimiterThreshold, Mode=TwoWay}"
                                         Min="0.1" Max="1" DefaultMin="0.8" DefaultMax="1" Delta="0.01"
                                         StringFormat="F2" Unit="" Width="200"
                                         HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Label Content="{x:Static loc:Texts.EnableCompression}" VerticalAlignment="Center"/>
                        <c:ToggleSlider Value="{Binding Effects.EnableCompression, Mode=TwoWay}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Label Content="{x:Static loc:Texts.CompressionThreshold}" VerticalAlignment="Center"/>
                        <c:TextBoxSlider Value="{Binding Effects.CompressionThreshold, Mode=TwoWay}"
                                         Min="0" Max="1" DefaultMin="0.5" DefaultMax="0.9" Delta="0.05"
                                         StringFormat="F2" Unit="" Width="200"
                                         HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Label Content="{x:Static loc:Texts.CompressionRatio}" VerticalAlignment="Center"/>
                        <c:TextBoxSlider Value="{Binding Effects.CompressionRatio, Mode=TwoWay}"
                                         Min="1" Max="20" DefaultMin="2" DefaultMax="8" Delta="0.5"
                                         StringFormat="F1" Unit=":1" Width="200"
                                         HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Label Content="{x:Static loc:Texts.EnableReverb}" VerticalAlignment="Center"/>
                        <c:ToggleSlider Value="{Binding Effects.EnableReverb, Mode=TwoWay}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Label Content="{x:Static loc:Texts.ReverbDecay}" VerticalAlignment="Center"/>
                        <c:TextBoxSlider Value="{Binding Effects.ReverbDecay, Mode=TwoWay}"
                                         Min="0" Max="1" DefaultMin="0.1" DefaultMax="0.5" Delta="0.01"
                                         StringFormat="F2" Unit="" Width="200"
                                         HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>
