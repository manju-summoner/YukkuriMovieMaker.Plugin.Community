<UserControl x:Class="YukkuriMovieMaker.Plugin.Community.FileWriter.MediaFoundationFast.Views.MediaFoundationFastConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:YukkuriMovieMaker.Plugin.Community.FileWriter.MediaFoundationFast.Localization"
             xmlns:m="clr-namespace:YukkuriMovieMaker.Plugin.Community.FileWriter.MediaFoundationFast.Models"
             xmlns:c="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Controls"
             xmlns:e="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Plugin"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="500">
    <StackPanel>

        <Expander Header="{x:Static loc:Texts.VideoSettings}" IsExpanded="True">
            <StackPanel>
                <Grid Height="26">
                    <Label Padding="4,0" VerticalContentAlignment="Center" Content="{x:Static loc:Texts.BitRateControlMode}" VerticalAlignment="Center"/>
                    <e:EnumComboBox EnumType="{x:Type m:VideoBitRateControlMode}"
                                    Value="{Binding Settings.VideoBitRateControlMode, Mode=TwoWay}"
                                    Width="200" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <Grid Height="26">
                    <Grid.Style>
                        <Style TargetType="{x:Type Grid}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Settings.VideoBitRateControlMode}" Value="Quality">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Label Padding="4,0" VerticalContentAlignment="Center" Content="{x:Static loc:Texts.VideoBitRate}" ToolTip="{x:Static loc:Texts.VideoBitRateAutoNote}" VerticalAlignment="Center"/>
                    <c:TextBoxSlider Value="{Binding Settings.VideoBitRate, Mode=TwoWay}"
                                     Min="0" Max="200000" DefaultMin="0" DefaultMax="50000" Delta="500"
                                     StringFormat="F0" Unit="kbps" Width="200"
                                     HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <Grid Height="26">
                    <Grid.Style>
                        <Style TargetType="{x:Type Grid}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Settings.VideoBitRateControlMode}" Value="Quality">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Label Padding="4,0" VerticalContentAlignment="Center" Content="{x:Static loc:Texts.VideoQuality}" VerticalAlignment="Center"/>
                    <c:TextBoxSlider Value="{Binding Settings.VideoQuality, Mode=TwoWay}"
                                     Min="1" Max="100" DefaultMin="1" DefaultMax="100" Delta="1"
                                     StringFormat="F0" Unit="" Width="200"
                                     HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <Grid Height="26">
                    <Label Padding="4,0" VerticalContentAlignment="Center" Content="{x:Static loc:Texts.EncodeSpeed}" ToolTip="{x:Static loc:Texts.EncodeSpeedNote}" VerticalAlignment="Center"/>
                    <c:TextBoxSlider Value="{Binding Settings.EncodeSpeed, Mode=TwoWay}"
                                     Min="0" Max="100" DefaultMin="0" DefaultMax="100" Delta="1"
                                     StringFormat="F0" Unit="" Width="200"
                                     HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <Grid Height="26">
                    <Label Padding="4,0" VerticalContentAlignment="Center" Content="{x:Static loc:Texts.NumberOfThreads}" ToolTip="{x:Static loc:Texts.ThreadsAutoNote}" VerticalAlignment="Center"/>
                    <c:TextBoxSlider Value="{Binding Settings.NumberOfThreads, Mode=TwoWay}"
                                     Min="0" Max="64" DefaultMin="0" DefaultMax="32" Delta="1"
                                     StringFormat="F0" Unit="" Width="200"
                                     HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <Grid Height="26">
                    <Label Padding="4,0" VerticalContentAlignment="Center" Content="{x:Static loc:Texts.GOPSize}" ToolTip="{x:Static loc:Texts.GOPSizeAutoNote}" VerticalAlignment="Center"/>
                    <c:TextBoxSlider Value="{Binding Settings.GOPSize, Mode=TwoWay}"
                                     Min="0" Max="600" DefaultMin="0" DefaultMax="300" Delta="1"
                                     StringFormat="F0" Unit="" Width="200"
                                     HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <Grid Height="26">
                    <Label Padding="4,0" VerticalContentAlignment="Center" Content="{x:Static loc:Texts.BFrameCount}" VerticalAlignment="Center"/>
                    <c:TextBoxSlider Value="{Binding Settings.BFrameCount, Mode=TwoWay}"
                                     Min="0" Max="16" DefaultMin="0" DefaultMax="4" Delta="1"
                                     StringFormat="F0" Unit="" Width="200"
                                     HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <Grid Height="26">
                    <Label Padding="4,0" VerticalContentAlignment="Center" Content="{x:Static loc:Texts.H264Profile}" VerticalAlignment="Center"/>
                    <e:EnumComboBox EnumType="{x:Type m:H264Profile}"
                                    Value="{Binding Settings.H264Profile, Mode=TwoWay}"
                                    Width="200" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <Grid Height="26">
                    <Label Padding="4,0" VerticalContentAlignment="Center" Content="{x:Static loc:Texts.H264Level}" ToolTip="{x:Static loc:Texts.H264LevelAutoNote}" VerticalAlignment="Center"/>
                    <e:EnumComboBox EnumType="{x:Type m:H264Level}"
                                    Value="{Binding Settings.H264Level, Mode=TwoWay}"
                                    Width="200" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <Grid Height="26">
                    <Label Padding="4,0" VerticalContentAlignment="Center" Content="{x:Static loc:Texts.HardwareAcceleration}" ToolTip="{x:Static loc:Texts.HardwareAccelerationNote}" VerticalAlignment="Center"/>
                    <c:ToggleSlider Value="{Binding Settings.IsHardwareAcceleration, Mode=TwoWay}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Expander>

        <Expander Header="{x:Static loc:Texts.AudioSettings}" IsExpanded="True">
            <StackPanel>
                <Grid Height="26">
                    <Label Padding="4,0" VerticalContentAlignment="Center" Content="{x:Static loc:Texts.AudioBitRate}" VerticalAlignment="Center"/>
                    <e:EnumComboBox EnumType="{x:Type m:AudioBitRate}"
                                    Value="{Binding Settings.AudioBitRate, Mode=TwoWay}"
                                    Width="200" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <Grid Height="26">
                    <Label Padding="4,0" VerticalContentAlignment="Center" Content="{x:Static loc:Texts.AACProfile}" VerticalAlignment="Center"/>
                    <e:EnumComboBox EnumType="{x:Type m:AACProfile}"
                                    Value="{Binding Settings.AACProfile, Mode=TwoWay}"
                                    Width="200" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Expander>

    </StackPanel>
</UserControl>
